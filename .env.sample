# ============================================================
#   Ultroid Optimized — Konfigurasi Lingkungan (.env)
#   Salin file ini: cp .env.sample .env
#   JANGAN gunakan tanda kutip (" atau ')
#   JANGAN bagikan file ini ke siapapun!
# ============================================================

# ─── WAJIB ───────────────────────────────────────────────────
# Dapatkan dari: https://my.telegram.org/apps
API_ID=
API_HASH=

# String sesi akun Anda. Generate dengan: python3 ssgen.py
SESSION=

# ─── BOT ASSISTANT (Sangat Disarankan) ───────────────────────
# Token bot dari @BotFather — digunakan untuk notifikasi & inline
BOT_TOKEN=

# ─── LOG CHANNEL ─────────────────────────────────────────────
# ID channel/grup untuk menerima log aktivitas bot
# Format: -100XXXXXXXXXX (channel) atau -XXXXXXXXX (grup)
LOG_CHANNEL=

# ─── DATABASE (Pilih salah satu atau kosongkan untuk LocalDB) ─
# Opsi 1: Redis (ringan & cepat, disarankan untuk VPS/cloud)
REDIS_URI=
REDIS_PASSWORD=

# Opsi 2: MongoDB (cocok untuk data banyak)
# MONGO_URI=

# Jika semua kosong → bot otomatis menggunakan LocalDB (file JSON)

# ─── SUDO USERS ──────────────────────────────────────────────
# ID Telegram pengguna yang dipercaya (pisahkan dengan spasi)
# Contoh: SUDO_USERS=123456789 987654321
SUDO_USERS=

# ─── FITUR AI (Opsional) ─────────────────────────────────────
# JANGAN bagikan API key ini ke siapapun!
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_KEY=
DEEPSEEK_API_KEY=

# ─── OPTIMASI PLATFORM ───────────────────────────────────────
# Set True untuk mode ringan (Termux / perangkat dengan RAM < 1GB)
# LITE_DEPLOY=True

# Nama platform (opsional, biasanya terdeteksi otomatis)
# HOSTED_ON=termux
