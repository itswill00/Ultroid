# ============================================================
#   Ultroid Optimized — Configuration Sample (.env)
#   Copy this file: cp .env.sample .env
#   DO NOT use quotes (" or ') around values.
#   DO NOT share your .env file with anyone!
# ============================================================

# --- MANDATORY CORE ---
# Get these from: https://my.telegram.org/apps
API_ID=
API_HASH=

# String session for your account.
# Generate using: python3 ssgen.py
SESSION=

# --- BOT ASSISTANT (Highly Recommended) ---
# Token from @BotFather — used for Assistant Mode & Sudo Redirection.
BOT_TOKEN=

# --- SECURITY & LOGGING ---
# Channel/Group ID for system logs & security alerts.
# Format: -100XXXXXXXXXX (channel) or -XXXXXXXXX (group)
LOG_CHANNEL=

# --- AI & RESEARCH (Groq) ---
# Required for .ask and .search features.
# Get your FREE key at: https://console.groq.com/
GROQ_API_KEY=

# --- CUSTOMIZATION ---
HNDLR=.               # Command prefix for Owner (Default: .)
SUDO_HNDLR=!          # Command prefix for Sudoers (Default: !)
OWNER_NAME=           # Your name for help menus
ALIVE_PIC=            # Image URL for .alive (Optional)

# --- SUDO & PERMISSIONS ---
SUDO=True             # Enable Sudo support (True/False)
ASST_SUDO_RESPOND=True # Bot Assistant responds to Sudoers (@bot)
SESSION_GUARD=True    # Monitor and alert on new account logins

# --- DATABASE (Local by Default) ---
# If left empty, the bot uses LocalDB (JSON file).
# For Redis Cloud:
REDIS_URI=
REDIS_PASSWORD=

# --- ADVANCED PLATFORM SETTINGS ---
VCBOT=False           # Enable Voice Chat features
ADDONS=False          # Load custom plugins from /addons folder
LITE_DEPLOY=False     # Optimize for Ultra-Low RAM (Termux)
HOSTED_ON=            # Optional: termux, vps, wsl, docker
# ============================================================
