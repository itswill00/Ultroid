# ============================================================
#   Ultroid Optimized — Configuration Sample
#   Copy this file: cp .env.sample .env
#   Do NOT use quotes (" or ') around values.
#   Do NOT share your .env file with anyone.
# ============================================================

# --- MANDATORY ---
# Get from: https://my.telegram.org/apps
API_ID=
API_HASH=

# String session for your account.
# Generate using: python3 ssgen.py
# Not required if RUNTIME_MODE=bot
SESSION=

# Bot token from @BotFather.
# Required for RUNTIME_MODE=bot or RUNTIME_MODE=dual
BOT_TOKEN=

# --- RUNTIME MODE ---
# Controls which Telegram clients are started.
#   dual  — userbot + assistant bot (default)
#   user  — userbot only, no separate bot
#   bot   — bot only, SESSION not required
RUNTIME_MODE=dual

# --- LOGGING ---
# Telegram channel or group ID for startup card and alerts.
# Format: -100XXXXXXXXXX (channel) or -XXXXXXXXX (group)
LOG_CHANNEL=

# --- AI (Groq) ---
# Required for .ask and .search commands.
# Free key at: https://console.groq.com/
GROQ_API_KEY=

# --- CUSTOMIZATION ---
HNDLR=.               # Command prefix for owner (default: .)
SUDO_HNDLR=!          # Command prefix for sudo users (default: !)
OWNER_NAME=           # Your display name for help menus (optional)
ALIVE_PIC=            # Image URL for .alive command (optional)

# --- PERMISSIONS ---
SUDO=True             # Enable sudo user support
ASST_SUDO_RESPOND=True # Let assistant bot respond to sudo commands

# --- DATABASE ---
# Leave empty to use LocalDB (JSON file — no setup required).
# Redis:
REDIS_URI=
REDIS_PASSWORD=
# MongoDB:
MONGO_URI=

# --- PLATFORM ---
VCBOT=False
ADDONS=False
# Lower memory profile for Termux/low-RAM devices (True/False)
LITE_DEPLOY=False
# Environment hint: termux | vps | wsl | docker
HOSTED_ON=

# ============================================================
