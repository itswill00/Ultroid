#!/usr/bin/env bash
# Ultroid Optimized — Termux Entry Point
# This script delegates to the unified installer.sh

set -e

# Detect if we are in the repo, if not clone it
if [ ! -d "pyUltroid" ]; then
    echo "Cloning Ultroid repository..."
    pkg update -y && pkg install git -y
    git clone https://github.com/itswill00/Ultroid
    cd Ultroid
fi

# Launch the unified smart installer
bash installer.sh
